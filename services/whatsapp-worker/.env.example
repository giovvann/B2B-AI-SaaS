# Puerto del servidor HTTP (default 3001)
PORT=3001

# Número de WhatsApp del dueño de Veliora (con código de país, sin +)
# Ejemplo: 528342177709
ADMIN_WHATSAPP=528342177709

# URL de la API de Veliora (para consultar alertas programadas)
# Si está en Vercel, poner la URL de producción
VELIORA_API_URL=https://b2b-ai-saas.vercel.app

# (Opcional) Auth token para seguridad entre servicios
# VELIORA_SECRET=tu-secreto-aqui
